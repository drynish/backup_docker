	    transport http {
		    tls
		    tls_insecure_skip_verify
      }
	  }
  }

  respond 403
}
plex.dicroci.website {
    @rootPath {
        path /
    }

    redir @rootPath /web/index.html

    reverse_proxy http://192.168.90.4:32400 {
        # Headers essentiels pour Plex
        header_up Host {host}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
        header_up X-Real-IP {remote}
        header_up X-Forwarded-For {remote}

        # Header CRITIQUE manquant (cause du spinner infini)
        header_up X-Plex-Client-Identifier {remote_host}
        
        # Timeout plus long pour Plex
        transport http {
	    versions 1.1
            read_timeout 0
            write_timeout 0
        }
    }
    tls {
        dns cloudflare {env.CLOUDFLARE_API_TOKEN}
    } 
    
}

