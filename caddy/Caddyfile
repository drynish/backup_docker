adguard.drynish.synology.me {
    @internal remote_ip 192.168.90.0/24 192.168.13.0/24
    handle @internal {
        reverse_proxy adguardhome:88
    }
    handle {
        forward_auth authelia:9091 {
            uri /api/verify?rd=https://auth.drynish.synology.me
            copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
        }
        reverse_proxy adguardhome:88
    }
    respond 403
}

